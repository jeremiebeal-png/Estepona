      {n:34, title:"La Imagen Vuelta", artist:"Fernando Clemente", location:"Avda. Andalucía, 57", year:"", meaning:"Jeu sur l’image / renversement de perception (interprétation)."},
      {n:35, title:"La Luna", artist:"Dadi Dreucol", location:"Avda. Andalucía, 67", year:"", meaning:"Astres / lune — poésie nocturne (interprétation)."},
      {n:36, title:"Llegando a tu Destino", artist:"Dourone", location:"Prolongación Avda. San Lorenzo, 17", year:"", meaning:"Voyage/arrivée — cheminement, but (interprétation)."},
      {n:37, title:"Paraíso Golf", artist:"Manuel León", location:"C/ Terraza, 168", year:"", meaning:"Univers golf / “paradis” sportif (interprétation)."},
      {n:38, title:"Musas", artist:"Lalone", location:"C/ Dos de Mayo (Bda. Solís)", year:"", meaning:"Muses — inspiration artistique, figures allégoriques (interprétation)."},
      {n:39, title:"Jump Into Blue", artist:"CAZL", location:"Pasaje Poetas Andaluces", year:"", meaning:"Plonger dans le bleu — mer/ciel, énergie (interprétation)."},
      {n:40, title:"Freaks", artist:"Rebelzer", location:"C/ Granada, 16", year:"", meaning:"Personnages décalés / culture urbaine (interprétation)."},
      {n:41, title:"Agua (en sistema Braille)", artist:"Fran Redondo", location:"C/ Málaga (Edf. Saymar)", year:"", meaning:"Accessibilité + thème de l’eau (interprétation basée sur le titre)."},
      {n:42, title:"Recuerdos Orientales", artist:"José Fernández Ríos", location:"Plaza Antonia Guerrero", year:"", meaning:"Souvenirs orientaux — motifs / ambiance (interprétation)."},
      {n:43, title:"Pórticos del Cielo", artist:"José Fernández Ríos", location:"Avda. Andalucía, 3", year:"", meaning:"Portiques vers le ciel — architecture / verticalité (interprétation)."},
      {n:44, title:"La Última Cena", artist:"Curro Leyton", location:"C/ Madrid (Iglesia San José)", year:"", meaning:"Référence à la Cène — iconographie religieuse (interprétation)."},
      {n:45, title:"Mural Histórico (S. XIX)", artist:"Anónimo", location:"Jardín de la Costa del Sol", year:"", meaning:"Fresque patrimoniale du XIXe siècle (factuel : historique)."},
      {n:46, title:"Espíritu de Equipo", artist:"Fco. Alarcón", location:"C/ Cristóbal Ruiz Méndez, Pabellón J.A. Pineda", year:"", meaning:"Sport collectif / cohésion (interprétation)."},
      {n:47, title:"Leyton", artist:"Curro Leyton", location:"C/ Virgen de la Cabeza (Colegio María Espinosa)", year:"", meaning:"Signature/hommage à l’artiste — identité visuelle (interprétation)."},
      {n:48, title:"Frescos de la Casa Mondéjar (S. XVIII)", artist:"Anónimo", location:"C/ Mondéjar", year:"", meaning:"Fresques patrimoniales du XVIIIe siècle (factuel : historique)."},
      {n:49, title:"Atlantas", artist:"José Fernández Ríos", location:"Avda. Andalucía, 115", year:"", meaning:"Atlantes — figures porteuses / mythologie architecturale (interprétation)."},
      {n:50, title:"Deporte para Todos", artist:"Félix García Álvarez", location:"Centro Deportivo José Ramón de la Morena", year:"", meaning:"Sport, santé, accessibilité — hommage aux sportifs (interprétation)."},
      {n:51, title:"Estepona se Viste de Flores", artist:"Susana Velasco", location:"C/ Félix Rodríguez de la Fuente", year:"", meaning:"Ville fleurie — identité d’Estepona (interprétation)."},
      {n:52, title:"Nutrir", artist:"Samantha Jordaan", location:"C/ Terraza (Conjunto Andalucía)", year:"", meaning:"Nourrir — soin, croissance, lien au vivant (interprétation)."},
      {n:53, title:"Sin Nombre", artist:"El Chorro Arts", location:"C/ Terraza (Bda. Isabel Simón) nº 1", year:"", meaning:"Œuvre sans titre — lecture libre (interprétation)."},
      {n:54, title:"La Caída", artist:"Vyacheslav Gunin", location:"C/ Peineta (Bda. Isabel Simón) nº 6", year:"2020", meaning:"Composition onirique — chute / rêve / nature (description synthèse)."},
      {n:55, title:"Sin Nombre", artist:"Alejandro Gambín Vicente", location:"C/ Santo Domingo de Guzmán, nº 7", year:"", meaning:"Œuvre sans titre — lecture libre (interprétation)."},
      {n:56, title:"Momento Pasajero", artist:"Ángel Caballero Rioja", location:"C/ Melilla (Edf. Royber)", year:"", meaning:"Instant fugace — temps qui passe (interprétation)."},
      {n:57, title:"Ilusión", artist:"José Antonio Barrientos", location:"C/ San Roque (Edf. Bustamante)", year:"", meaning:"Rêve/illusion — imaginaire (interprétation)."},
      {n:58, title:"Sin Nombre", artist:"Alex Senna", location:"C/ Cristobal Ruiz Méndez (Edf. Soto)", year:"", meaning:"Œuvre sans titre — lecture libre (interprétation)."},
      {n:59, title:"La Fase Azul de Pajarito Curioso", artist:"André Farkos", location:"C/ San Juan Bosco", year:"", meaning:"Oiseau curieux — “phase bleue”, poésie chromatique (interprétation)."},
      {n:60, title:"Fragmentación de un Entorno Concreto", artist:"Alberto Montes Sánchez", location:"Prolongación Avda. San Lorenzo, nº 25", year:"", meaning:"Fragmentation urbaine — abstraction / architecture (interprétation)."},
      {n:61, title:"Fémina", artist:"Curro Leyton", location:"Polideportivo La Lobilla", year:"", meaning:"Figure féminine — force/présence (interprétation)."},
      {n:62, title:"El Pescador Moderno", artist:"Juan Pineda", location:"C/ San Juan Bosco", year:"", meaning:"Pêcheur contemporain — lien tradition/modernité (interprétation)."}
    ];

    // UI elements
    const q = document.getElementById("q");
    const artist = document.getElementById("artist");
    const zone = document.getElementById("zone");
    const year = document.getElementById("year");
    const cards = document.getElementById("cards");
    const tbody = document.getElementById("tbody");
    const totalCount = document.getElementById("totalCount");
    const shownCount = document.getElementById("shownCount");
    const metaLine = document.getElementById("metaLine");
    const viewSwitch = document.getElementById("viewSwitch");
    const descSwitch = document.getElementById("descSwitch");
    const tableWrap = document.getElementById("table");
    const copyAllBtn = document.getElementById("copyAllBtn");
    const resetBtn = document.getElementById("resetBtn");

    totalCount.textContent = murals.length;

    // Populate artist dropdown
    const artists = [...new Set(murals.map(m => m.artist))].sort((a,b)=>a.localeCompare(b,"fr"));
    for (const a of artists){
      const opt = document.createElement("option");
      opt.value = a;
      opt.textContent = a;
      artist.appendChild(opt);
    }

    function norm(s){
      return (s || "")
        .toString()
        .normalize("NFD").replace(/[\u0300-\u036f]/g,"")
        .toLowerCase()
        .trim();
    }

    function buildMapLink(text){
      const query = encodeURIComponent((text || "") + " Estepona");
      return `https://www.google.com/maps/search/?api=1&query=${query}`;
    }

    function copyToClipboard(text){
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(text);
    }

    function currentFilters(){
      return {
        q: norm(q.value),
        artist: artist.value,
        zone: zone.value,
        year: year.value,
        hideInterp: descSwitch.classList.contains("on")
      };
    }

    function isInterpretative(meaning){
      // heuristic: on marque comme “interprétatif” les phrases contenant "(interprétation"
      return /\(interprétation/i.test(meaning || "");
    }

    function apply(){
      const f = currentFilters();
      let list = murals.slice();

      if (f.artist){
        list = list.filter(m => m.artist === f.artist);
      }
      if (f.year){
        list = list.filter(m => (m.year || "") === f.year);
      }
      if (f.zone){
        list = list.filter(m => (m.location || "").includes(f.zone));
      }
      if (f.q){
        list = list.filter(m => {
          const blob = norm([m.title,m.artist,m.location,m.meaning,m.year].join(" "));
          return blob.includes(f.q);
        });
      }
      if (f.hideInterp){
        list = list.map(m => ({
          ...m,
          meaning: isInterpretative(m.meaning) ? "" : m.meaning
        }));
      }

      render(list);
      return list;
    }

    function render(list){
      shownCount.textContent = list.length;
      metaLine.textContent = `${list.length} œuvre(s) — tri par numéro`;

      // Cards
      cards.innerHTML = "";
      for (const m of list){
        const el = document.createElement("article");
        el.className = "mural";

        const mapLink = buildMapLink(`${m.title} ${m.location}`);
        const copyLine = `#${m.n} — ${m.title} — ${m.artist} — ${m.location}${m.year ? " — " + m.year : ""}`;

        el.innerHTML = `
          <div class="top">
            <div>
              <h3>${escapeHtml(m.title)}</h3>
              <p class="who">${escapeHtml(m.artist)}</p>
            </div>
            <div class="badge">#${m.n}</div>
          </div>

          <div class="row">
            <span class="pill">📍 ${escapeHtml(m.location)}</span>
            ${m.year ? `<span class="pill">🗓️ ${escapeHtml(m.year)}</span>` : `<span class="pill">🗓️ année : —</span>`}
          </div>

          ${m.meaning ? `<p class="desc">${escapeHtml(m.meaning)}</p>` : `<p class="desc" style="color:rgba(234,246,248,.65)">—</p>`}

          <div class="actions">
            <a class="link map" target="_blank" rel="noopener" href="${mapLink}">🗺️ Ouvrir sur Maps</a>
            <a class="link copy" href="javascript:void(0)" data-copy="${escapeAttr(copyLine)}">📋 Copier</a>
          </div>
        `;
        cards.appendChild(el);
      }

      // Table
      tbody.innerHTML = "";
      for (const m of list){
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td><span style="font-family:var(--mono)">#${m.n}</span></td>
          <td>${escapeHtml(m.title)}</td>
          <td>${escapeHtml(m.artist)}</td>
          <td>${escapeHtml(m.location)}</td>
          <td>${m.year ? escapeHtml(m.year) : "—"}</td>
          <td>${m.meaning ? escapeHtml(m.meaning) : "—"}</td>
        `;
        tbody.appendChild(tr);
      }

      // Bind copy buttons
      cards.querySelectorAll("[data-copy]").forEach(btn=>{
        btn.addEventListener("click", ()=>{
          copyToClipboard(btn.getAttribute("data-copy"));
          btn.textContent = "✅ Copié";
          setTimeout(()=>btn.textContent="📋 Copier", 900);
        });
      });
    }

    function escapeHtml(str){
      return (str ?? "").toString()
        .replaceAll("&","&amp;")
        .replaceAll("<","&lt;")
        .replaceAll(">","&gt;")
        .replaceAll('"',"&quot;")
        .replaceAll("'","&#039;");
    }
    function escapeAttr(str){ return escapeHtml(str); }

    function toggleSwitch(el){
      const on = !el.classList.contains("on");
      el.classList.toggle("on", on);
      el.setAttribute("aria-checked", on ? "true" : "false");
      return on;
    }

    // Switch: view
    function syncView(){
      const tableOn = viewSwitch.classList.contains("on");
      tableWrap.style.display = tableOn ? "block" : "none";
      cards.style.display = tableOn ? "none" : "grid";
    }
    viewSwitch.addEventListener("click", ()=>{ toggleSwitch(viewSwitch); syncView(); });
    viewSwitch.addEventListener("keydown", (e)=>{ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); toggleSwitch(viewSwitch); syncView(); }});

    // Switch: hide interpretative descriptions
    descSwitch.addEventListener("click", ()=>{ toggleSwitch(descSwitch); apply(); });
    descSwitch.addEventListener("keydown", (e)=>{ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); toggleSwitch(descSwitch); apply(); }});

    // Filters
    [q, artist, zone, year].forEach(el => el.addEventListener("input", apply));
    [artist, zone, year].forEach(el => el.addEventListener("change", apply));

    // Copy filtered list
    copyAllBtn.addEventListener("click", ()=>{
      const list = apply();
      const txt = list.map(m => `#${m.n}\t${m.title}\t${m.artist}\t${m.location}\t${m.year || ""}`).join("\n");
      copyToClipboard(txt);
      copyAllBtn.textContent = "✅ Liste copiée";
      setTimeout(()=>copyAllBtn.textContent="📋 Copier la liste filtrée", 1100);
    });

    // Reset
    resetBtn.addEventListener("click", ()=>{
      q.value = "";
      artist.value = "";
      zone.value = "";
      year.value = "";
      descSwitch.classList.remove("on");
      descSwitch.setAttribute("aria-checked","false");
      apply();
    });

    // Init
    apply();
    syncView();
  </script>
</body>
</html>
