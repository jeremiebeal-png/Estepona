<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Route des fresques d’Estepona — Murales, artistes & emplacements</title>
  <meta name="description" content="La route des fresques d’Estepona : liste des œuvres, artistes, lieux, recherche et filtres." />
  <meta name="theme-color" content="#0b3c49" />

  <style>
    :root{
      --bg:#071f26;
      --panel:#0b2f38;
      --panel2:#0d3640;
      --text:#eaf6f8;
      --muted:rgba(234,246,248,.75);
      --soft:rgba(234,246,248,.10);
      --soft2:rgba(234,246,248,.16);
      --brand:#0b3c49;
      --accent:#2dd4bf;
      --warn:#fbbf24;
      --radius:18px;
      --shadow:0 14px 40px rgba(0,0,0,.35);
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:var(--sans);
      color:var(--text);
      background:
        radial-gradient(1100px 600px at 16% -10%, rgba(45,212,191,.16), transparent 60%),
        radial-gradient(900px 520px at 88% 10%, rgba(14,165,233,.14), transparent 55%),
        linear-gradient(180deg, #04171c 0%, #061e25 45%, #04171c 100%);
    }
    a{color:inherit}
    .container{max-width:1200px;margin:0 auto;padding:24px}
    header{
      position:sticky;top:0;z-index:50;
      backdrop-filter: blur(10px);
      background: rgba(4,23,28,.72);
      border-bottom: 1px solid rgba(234,246,248,.08);
    }
    .header-inner{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 24px;max-width:1200px;margin:0 auto}
    .brand{display:flex;align-items:center;gap:12px}
    .logo{
      width:38px;height:38px;border-radius:12px;
      background: linear-gradient(135deg, rgba(45,212,191,.95), rgba(14,165,233,.75));
      box-shadow: 0 10px 28px rgba(0,0,0,.3);
    }
    .brand h1{font-size:15px;letter-spacing:.2px;margin:0}
    .brand p{margin:0;font-size:12px;color:var(--muted)}
    .chip{
      display:inline-flex;align-items:center;gap:8px;
      padding:8px 10px;border-radius:999px;
      background: rgba(234,246,248,.08);
      border: 1px solid rgba(234,246,248,.12);
      color: var(--muted);
      font-size:12px;
      white-space:nowrap;
    }

    .hero{
      padding:22px 0 8px;
    }
    .hero-grid{
      display:grid;grid-template-columns: 1.2fr .8fr;gap:18px;align-items:stretch;
    }
    .card{
      background: linear-gradient(180deg, rgba(11,47,56,.78), rgba(11,47,56,.55));
      border: 1px solid rgba(234,246,248,.10);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .card .pad{padding:18px}
    .title{
      font-size:28px;line-height:1.15;margin:0 0 8px;
      letter-spacing:.2px;
    }
    .subtitle{margin:0;color:var(--muted);line-height:1.5;font-size:14px}
    .note{
      margin-top:12px;
      padding:12px 12px;
      border-radius: 14px;
      background: rgba(251,191,36,.10);
      border: 1px solid rgba(251,191,36,.22);
      color: rgba(255,245,214,.95);
      font-size:13px;
    }
    .note strong{color:#fff}
    .quick{
      display:flex;flex-wrap:wrap;gap:10px;margin-top:14px
    }
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:10px;
      padding:10px 12px;border-radius:14px;
      background: rgba(234,246,248,.09);
      border: 1px solid rgba(234,246,248,.12);
      color: var(--text);
      text-decoration:none;
      font-size:13px;
      transition:transform .08s ease, background .08s ease, border-color .08s ease;
      cursor:pointer;
      user-select:none;
    }
    .btn:hover{transform:translateY(-1px);background:rgba(234,246,248,.12);border-color:rgba(234,246,248,.18)}
    .btn.primary{
      background: linear-gradient(135deg, rgba(45,212,191,.95), rgba(14,165,233,.78));
      border: none;
      color:#072127;
      font-weight:700;
    }
    .btn.primary:hover{filter:brightness(1.04)}
    .stat{
      display:grid;grid-template-columns:1fr 1fr;gap:12px
    }
    .stat .box{
      border-radius: 16px;
      background: rgba(234,246,248,.06);
      border: 1px solid rgba(234,246,248,.10);
      padding:14px;
    }
    .stat .k{font-size:12px;color:var(--muted);margin:0 0 6px}
    .stat .v{margin:0;font-size:20px;font-weight:800}
    .stat .s{margin:6px 0 0;color:var(--muted);font-size:12px}
    .tools{
      display:grid;grid-template-columns: 1fr;gap:12px;margin-top:12px
    }

    /* Controls */
    .controls{
      margin-top:14px;
      display:grid;
      grid-template-columns: 1.1fr .6fr .6fr .45fr;
      gap:10px;
    }
    .field{
      border-radius: 16px;
      background: rgba(234,246,248,.06);
      border: 1px solid rgba(234,246,248,.12);
      padding:10px 12px;
      display:flex;flex-direction:column;gap:6px;
      min-height:62px;
    }
    .field label{font-size:11px;color:var(--muted)}
    input[type="text"], select{
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-size:14px;
      padding:2px 0;
    }
    select option{color:#061e25}
    .toggle{
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      padding:12px 12px;
      border-radius:16px;
      background: rgba(234,246,248,.06);
      border: 1px solid rgba(234,246,248,.12);
    }
    .toggle .lbl{font-size:12px;color:var(--muted);line-height:1.2}
    .switch{
      width:46px;height:28px;border-radius:999px;
      border:1px solid rgba(234,246,248,.18);
      background: rgba(234,246,248,.08);
      position:relative;cursor:pointer;flex:0 0 auto;
    }
    .switch::after{
      content:"";position:absolute;top:3px;left:3px;
      width:22px;height:22px;border-radius:999px;
      background: rgba(234,246,248,.90);
      transition:left .12s ease;
    }
    .switch.on{background:rgba(45,212,191,.22);border-color:rgba(45,212,191,.35)}
    .switch.on::after{left:21px;background:rgba(45,212,191,.95)}
    .results-head{
      margin-top:18px;
      display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;
    }
    .results-head h2{margin:0;font-size:16px}
    .results-head .meta{color:var(--muted);font-size:12px}

    /* Cards list */
    .grid{
      margin-top:12px;
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:12px;
    }
    .mural{
      border-radius: 18px;
      background: rgba(234,246,248,.05);
      border: 1px solid rgba(234,246,248,.10);
      padding:14px;
      display:flex;flex-direction:column;gap:10px;
      min-height: 190px;
    }
    .mural .top{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
    .badge{
      font-family:var(--mono);
      font-size:12px;
      padding:6px 8px;border-radius:999px;
      background: rgba(45,212,191,.12);
      border: 1px solid rgba(45,212,191,.20);
      color: rgba(230,255,252,.95);
      flex:0 0 auto;
    }
    .mural h3{margin:0;font-size:14px;line-height:1.25}
    .mural .who{margin:0;color:var(--muted);font-size:12px}
    .row{
      display:flex;gap:10px;flex-wrap:wrap;align-items:center;
      color: var(--muted);font-size:12px;
    }
    .pill{
      padding:6px 8px;border-radius:999px;
      background: rgba(234,246,248,.06);
      border: 1px solid rgba(234,246,248,.10);
    }
    .desc{margin:0;color:rgba(234,246,248,.88);font-size:13px;line-height:1.45}
    .mural .actions{margin-top:auto;display:flex;gap:10px;flex-wrap:wrap}
    .link{
      text-decoration:none;
      padding:8px 10px;border-radius:12px;
      background: rgba(234,246,248,.08);
      border: 1px solid rgba(234,246,248,.12);
      font-size:12px;color:var(--text);
    }
    .link:hover{background:rgba(234,246,248,.12)}
    .link.map{border-color:rgba(45,212,191,.22)}
    .link.copy{border-color:rgba(14,165,233,.22)}

    /* Table */
    .tablewrap{
      margin-top:12px;
      border-radius: 18px;
      background: rgba(234,246,248,.05);
      border: 1px solid rgba(234,246,248,.10);
      overflow:hidden;
    }
    table{width:100%;border-collapse:collapse}
    th,td{padding:12px 12px;border-bottom:1px solid rgba(234,246,248,.08);vertical-align:top}
    th{text-align:left;font-size:12px;color:var(--muted);font-weight:600;background:rgba(234,246,248,.04)}
    td{font-size:13px;color:rgba(234,246,248,.90)}
    td small{display:block;color:var(--muted);margin-top:4px}
    tr:hover td{background:rgba(234,246,248,.03)}
    .foot{
      margin:26px 0 10px;
      color: var(--muted);
      font-size:12px;
      line-height:1.5;
    }
    .divider{height:1px;background:rgba(234,246,248,.10);margin:18px 0}

    @media (max-width: 980px){
      .hero-grid{grid-template-columns:1fr}
      .grid{grid-template-columns: repeat(2, 1fr)}
      .controls{grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 620px){
      .grid{grid-template-columns: 1fr}
      .controls{grid-template-columns: 1fr; }
      .header-inner{padding:12px 16px}
      .container{padding:18px}
      .title{font-size:24px}
    }
  </style>
</head>

<body>
  <header>
    <div class="header-inner">
      <div class="brand">
        <div class="logo" aria-hidden="true"></div>
        <div>
          <h1>Vivre à Estepona — Route des fresques</h1>
          <p>Murales · artistes · lieux · recherche</p>
        </div>
      </div>

      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <span class="chip" id="todayChip">📍 Estepona</span>
        <a class="btn" href="#liste">Aller à la liste</a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- Bloc de navigation (demandé) -->
    <div style="display:flex;gap:16px;flex-wrap:wrap;margin:10px 0 16px">
      <a class="btn" href="index.html">Accueil</a>
      <a class="btn" href="infos-pratiques.html">Infos pratiques</a>
      <a class="btn" href="vieille-ville-fresques.html">Vieille ville & fresques</a>
      <a class="btn primary" href="route-fresques-estepona.html" aria-current="page">Route des fresques</a>
    </div>

    <section class="hero">
      <div class="hero-grid">
        <div class="card">
          <div class="pad">
            <h2 class="title">Route des fresques d’Estepona</h2>
            <p class="subtitle">
              Une galerie à ciel ouvert : ci-dessous, une liste structurée des œuvres (titre, artiste, lieu),
              avec recherche et filtres pour préparer ta balade.
            </p>

            <div class="note">
              <strong>Note “description” :</strong> pour la majorité des œuvres, la source consultée fournit le
              <em>titre / artiste / lieu</em> mais pas l’explication officielle. La colonne “Ce que ça représente”
              est donc parfois une <em>interprétation courte basée sur le titre</em>. Pour les fresques les plus connues,
              j’ai repris des détails publiés dans des articles de visite.
            </div>

            <div class="quick">
              <a class="btn primary" href="#liste">🔎 Rechercher une fresque</a>
              <a class="btn" id="copyAllBtn" href="javascript:void(0)">📋 Copier la liste filtrée</a>
              <a class="btn" id="resetBtn" href="javascript:void(0)">↩︎ Réinitialiser</a>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="pad">
            <div class="stat">
              <div class="box">
                <p class="k">Œuvres listées</p>
                <p class="v" id="totalCount">62</p>
                <p class="s">Base : dépliant 2022</p>
              </div>
              <div class="box">
                <p class="k">Affichées</p>
                <p class="v" id="shownCount">62</p>
                <p class="s">selon tes filtres</p>
              </div>
            </div>

            <div class="tools">
              <div class="toggle">
                <div>
                  <div class="lbl">Affichage</div>
                  <div class="lbl" style="margin-top:4px;color:rgba(234,246,248,.9)">Cartes / Tableau</div>
                </div>
                <div class="switch" id="viewSwitch" role="switch" aria-checked="false" tabindex="0"></div>
              </div>

              <div class="toggle">
                <div>
                  <div class="lbl">Masquer les descriptions “interprétatives”</div>
                  <div class="lbl" style="margin-top:4px;color:rgba(234,246,248,.9)">Ne garder que “factuel”</div>
                </div>
                <div class="switch" id="descSwitch" role="switch" aria-checked="false" tabindex="0"></div>
              </div>

              <a class="btn" href="https://www.google.com/maps/search/?api=1&query=Estepona%20murales%20ruta" target="_blank" rel="noopener">
                🗺️ Rechercher “murales” sur Google Maps
              </a>
            </div>
          </div>
        </div>
      </div>

      <div id="liste" class="divider"></div>

      <div class="controls">
        <div class="field">
          <label for="q">Recherche (titre, artiste, lieu)</label>
          <input id="q" type="text" placeholder="ex: Quijote, Leyton, Avda. Andalucía…" autocomplete="off" />
        </div>

        <div class="field">
          <label for="artist">Artiste</label>
          <select id="artist">
            <option value="">Tous</option>
          </select>
        </div>

        <div class="field">
          <label for="zone">Zone / rue (contient)</label>
          <select id="zone">
            <option value="">Toutes</option>
            <option value="Avda. Andalucía">Avda. Andalucía</option>
            <option value="C/ Terraza">C/ Terraza</option>
            <option value="Plaza">Plaza</option>
            <option value="Bda.">Barriada (Bda.)</option>
            <option value="Polideportivo">Polideportivo</option>
            <option value="Colegio">Colegio / Instituto</option>
          </select>
        </div>

        <div class="field">
          <label for="year">Année (si connue)</label>
          <select id="year">
            <option value="">Toutes</option>
            <option value="2012">2012</option>
            <option value="2013">2013</option>
            <option value="2014">2014</option>
            <option value="2015">2015</option>
            <option value="2016">2016</option>
            <option value="2020">2020</option>
            <option value="2022">2022</option>
          </select>
        </div>
      </div>
    </section>

    <section class="results">
      <div class="results-head">
        <h2>Résultats</h2>
        <div class="meta" id="metaLine">62 œuvres — tri par numéro</div>
      </div>

      <div id="cards" class="grid" aria-live="polite"></div>

      <div id="table" class="tablewrap" style="display:none" aria-live="polite">
        <table>
          <thead>
            <tr>
              <th style="width:70px">#</th>
              <th>Titre</th>
              <th>Artiste</th>
              <th>Lieu</th>
              <th style="width:90px">Année</th>
              <th>Ce que ça représente</th>
            </tr>
          </thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>

      <p class="foot">
        Astuce : certaines œuvres peuvent évoluer (rénovation, remplacement, retrait). Pour vérifier sur place,
        garde l’œil sur les panneaux et infos locales.
      </p>
    </section>
  </main>

